# Copy to .env and fill in the provider you use.
# Only one provider needs to be configured.

# ── Cloud providers ───────────────────────────────────────────────────────────

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Logfire observability (optional — leave blank to skip)
LOGFIRE_TOKEN=

# Langfuse observability (required for benchmark runs)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Either variable works:
# LANGFUSE_HOST=...
# LANGFUSE_BASE_URL=...
LANGFUSE_HOST=https://cloud.langfuse.com
# Performance controls:
# Default true: logs tool spans + timeline + reasoning parts (if available).
LANGFUSE_DETAILED_TRACING=true
# Keep this false for lower latency; true forces a network flush every run.
LANGFUSE_FLUSH_EACH_RUN=false
# 1.0 traces all runs, 0.2 traces ~20% of runs.
LANGFUSE_TRACE_SAMPLE_RATE=1.0

# ── Local / LM Studio ─────────────────────────────────────────────────────────
# Point at any OpenAI-compatible server (LM Studio, Ollama, llama.cpp, etc.)
#
# 1. Set the base URL of your local server (LM Studio default shown):
AGENT_BENCH_LOCAL_BASE_URL=http://192.168.68.60:1234/v1
#
# 2. Use the "local:" prefix in AGENT_BENCH_MODEL and paste the model name
#    exactly as shown in LM Studio's "Model" dropdown, e.g.:
#      local:lmstudio-community/Meta-Llama-3.1-8B-Instruct-GGUF
#      local:mistral-7b-instruct-v0.3
AGENT_BENCH_LOCAL_API_KEY=lm-studio

# ── Active model ──────────────────────────────────────────────────────────────
# Cloud examples:   anthropic:claude-sonnet-4-6   openai:gpt-4o
# Local example:    local:lmstudio-community/Meta-Llama-3.1-8B-Instruct-GGUF
AGENT_BENCH_MODEL=anthropic:claude-sonnet-4-6

# ── Native MCP (optional) ───────────────────────────────────────────────────────
# Only required by the `enterprise-mcp-react-native` architecture. Native MCP tool
# calls are made server-side by the model provider, so localhost is not reachable —
# expose `uv run python -m agent_harness.mcp_server` (streamable-HTTP transport)
# behind a public tunnel (e.g. ngrok) and paste that URL here.
ENTERPRISE_MCP_PUBLIC_URL=
