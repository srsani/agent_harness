# Copy to .env and fill in the provider you use.
# Only one provider needs to be configured.

# ── Cloud providers ───────────────────────────────────────────────────────────

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Logfire observability (optional — leave blank to skip)
LOGFIRE_TOKEN=

# ── Local / LM Studio ─────────────────────────────────────────────────────────
# Point at any OpenAI-compatible server (LM Studio, Ollama, llama.cpp, etc.)
#
# 1. Set the base URL of your local server (LM Studio default shown):
AGENT_BENCH_LOCAL_BASE_URL=http://192.168.68.60:1234/v1
#
# 2. Use the "local:" prefix in AGENT_BENCH_MODEL and paste the model name
#    exactly as shown in LM Studio's "Model" dropdown, e.g.:
#      local:lmstudio-community/Meta-Llama-3.1-8B-Instruct-GGUF
#      local:mistral-7b-instruct-v0.3
AGENT_BENCH_LOCAL_API_KEY=lm-studio

# ── Active model ──────────────────────────────────────────────────────────────
# Cloud examples:   anthropic:claude-sonnet-4-6   openai:gpt-4o
# Local example:    local:lmstudio-community/Meta-Llama-3.1-8B-Instruct-GGUF
AGENT_BENCH_MODEL=anthropic:claude-sonnet-4-6
